# Backend
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider
# mock is deterministic and requires no secrets.
LLM_PROVIDER=mock
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=
LLM_MODEL=amd-vllm-openai-compatible-model
LLM_TEXT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
LLM_CRITIC_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
LLM_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
LLM_RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=384
LLM_DISABLE_THINKING=true
LLM_AUXILIARY_REVIEWS=false

# Retrieval / vector store
# local = deterministic in-process vectors for dev and tests.
# qdrant = HTTP integration with a running Qdrant service.
VECTOR_BACKEND=local
VECTOR_BASE_URL=http://localhost:6333
VECTOR_KB_COLLECTION=anirvium_sarvagun_kb
VECTOR_MEMORY_COLLECTION=anirvium_superturiya_memory
VECTOR_TRAJECTORY_COLLECTION=anirvium_superturiya_trajectories
VECTOR_DIMENSION=64

# Agent memory
MEMORY_BACKEND=local
REDIS_URL=redis://localhost:6379/0
SHORT_TERM_MEMORY_TTL_SECONDS=3600
MID_TERM_MEMORY_LIMIT=50

# Exact operational truth for the hackathon demo.
RELATIONAL_DB_PATH=app/data/sarvagun_operational.sqlite3

# Benchmark metadata displayed in the app
AMD_PROVIDER_NAME=AMD Developer Cloud
AMD_BACKEND_NAME=vLLM/ROCm
AMD_GPU_NAME=AMD GPU (runtime-reported)
AMD_RUNTIME_PROFILE=text_48gb
